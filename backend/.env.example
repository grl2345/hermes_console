# 后端监听端口
PORT=8080

# Docker 守护进程地址
# Linux 本机：unix:///var/run/docker.sock
# 远程 TCP：tcp://1.2.3.4:2375
DOCKER_HOST=unix:///var/run/docker.sock

# CORS 允许的前端来源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000

# 共享 API Key（前端的 REMOTE_SERVER_API_KEY 必须与之一致）
# 留空则不校验（仅建议本地开发使用）
API_KEY=

# 内置管理员账号（阶段 0 无数据库，仅从环境变量读取）
ADMIN_EMAIL=admin@hermes.ai
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# 登录 token 有效期（小时）
TOKEN_TTL_HOURS=168

# ---- Agent 识别 ----
# 主：带 label `hermes.agent=true` 的容器被视为 Hermes agent
HERMES_LABEL_KEY=hermes.agent
HERMES_LABEL_VALUE=true
# 兜底：容器名以此前缀开头的也被识别；留空可禁用
HERMES_NAME_PREFIX=hermes-

# 技能文件默认目录（容器 label `hermes.skillsDir` 可覆盖单个 agent）
HERMES_SKILLS_DIR=/root/.claude/skills

# 定时任务到点时，在 agent 容器内执行的脚本
# 调用形式：<handler> <task-name>
# 可被容器 label `hermes.taskHandler` 覆盖
HERMES_TASK_HANDLER=/hermes/run-task.sh

# 调度器时区
HERMES_TIMEZONE=Asia/Shanghai
